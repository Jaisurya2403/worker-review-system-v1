# ============================================================
# COPY THIS FILE → rename to .env → fill in your values
# ============================================================

# ── MySQL / Aiven Database ───────────────────────────────────
DB_HOST=your-aiven-mysql-host.aivencloud.com
DB_PORT=3306
DB_USER=avnadmin
DB_PASSWORD=your_aiven_db_password
DB_NAME=worker_review_db
DB_SSL=true

# ── JWT Secret (make it long & random) ───────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_at_least_32_chars

# ── Server ───────────────────────────────────────────────────
PORT=5000

# ── CORS: your Vercel frontend URL ───────────────────────────
FRONTEND_URL=https://your-app.vercel.app

# ── Base URL for QR code links (your Vercel frontend URL) ────
BASE_URL=https://your-app.vercel.app

# ── Cloudinary (free tier - for worker images) ───────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Keep-Alive Self-Ping (your Render backend URL) ───────────
# This pings your own server every 14 min to prevent Render sleep
BACKEND_URL=https://your-app.onrender.com

# ── Image Storage Mode ────────────────────────────────────────
# Options: "cloudinary" or "local"
# Switch to "local" for local dev without Cloudinary
IMAGE_STORAGE=cloudinary
